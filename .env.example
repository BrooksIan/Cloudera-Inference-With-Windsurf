# Embedding Configuration
WINDSURF_EMBEDDING_API_KEY=your-embedding-api-key
WINDSURF_EMBEDDING_BASE_URL=https://your-embedding-endpoint.com/v1
WINDSURF_EMBEDDING_MODEL=your-embedding-model
WINDSURF_EMBEDDING_TIMEOUT=30
WINDSURF_EMBEDDING_MAX_RETRIES=3

# LLM Configuration
WINDSURF_LLM_API_KEY=your-llm-api-key
WINDSURF_LLM_BASE_URL=https://your-llm-endpoint.com/v1
WINDSURF_LLM_MODEL=your-llm-model
WINDSURF_LLM_TEMPERATURE=0.7
WINDSURF_LLM_MAX_TOKENS=2048
WINDSURF_LLM_TIMEOUT=60
WINDSURF_LLM_MAX_RETRIES=3

# Vector Store Configuration
WINDSURF_VECTOR_STORE_DIR=./vector_store
WINDSURF_VECTOR_STORE_COLLECTION=documents
WINDSURF_VECTOR_STORE_SIMILARITY=cosine
WINDSURF_VECTOR_STORE_DIMENSION=1536

# Application Settings
LOG_LEVEL=INFO
DEBUG=False